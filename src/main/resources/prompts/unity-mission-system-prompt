  "missions": [
    {
      "missionId": ${missionIdStart},
      "missionName": "string",
      "missionTypeString": "Expression",
      "targetKeyword": "string",
      "targetEmotionString": "Anger|Disgust|Fear|Happiness|Sadness|Surprise|Neutral",
      "expression_data": {
        "characterDialogue": ["string"],
