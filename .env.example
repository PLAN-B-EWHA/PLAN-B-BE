# Backend environment example
# Copy to .env or set these values in Render/Docker environment variables.

# Spring profile
SPRING_PROFILE=dev

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/myexpressionfriend
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# JWT
JWT_SECRET=replace-with-a-32-byte-or-longer-secret
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=Lax

# CORS
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173

# File storage
APP_STORAGE_BASE_PATH=uploads

# Gemini LLM (optional)
LLM_GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_TIMEOUT_MS=15000

# Report scheduler (optional)
REPORT_SCHEDULER_ENABLED=true
REPORT_SCHEDULER_DELAY_MS=60000